# Copy this file to .env and fill in your Smartling credentials.
# Find these in Smartling → Account Settings → API Tokens.

SMARTLING_USER_ID=your_user_identifier_here
SMARTLING_USER_SECRET=your_user_secret_here

# Optional — if not set, the tool will auto-detect it from the API.
# SMARTLING_ACCOUNT_UID=your_account_uid_here
